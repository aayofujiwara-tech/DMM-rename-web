{
  "name": "dmm-rename-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build && node -e \"require('fs').copyFileSync('.open-next/worker.js','.open-next/assets/_worker.js')\"",
    "preview": "npm run cf:build && wrangler pages dev .open-next/assets",
    "deploy": "npm run cf:build && wrangler pages deploy .open-next/assets"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "jszip": "^3.10.1",
    "next": "^15.5.19",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "sharp": "^0.35.1",
    "wrangler": "^4.102.0"
  }
}
